{
  "name": "webrtc-iframe-vue",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm -C examples/basic dev",
    "build": "pnpm -C packages/unity-stream-player build",
    "build:example": "pnpm -C examples/basic build",
    "preview": "pnpm -C examples/basic preview",
    "lint": "eslint . --ext .vue,.ts,.js",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && changeset publish",
    "install:all": "pnpm install",
    "clean": "rm -rf node_modules packages/*/node_modules examples/*/node_modules pnpm-lock.yaml",
    "reset": "pnpm run clean && pnpm install",
    "build:all": "pnpm run build && pnpm run build:example"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.1",
    "@types/node": "^20.10.0",
    "eslint": "^8.56.0",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "eslint-plugin-vue": "^9.19.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@9.0.2"
}
