# ==========================================
# Unity Render Streaming (URS) 配置
# ==========================================

# URS HTTP API 服务器地址
VITE_URS_SERVER_URL=http://你的IP地址:80

# URS WebSocket 信令服务器地址
VITE_URS_SIGNAL_URL=ws://你的IP地址:80

# 默认房间ID
VITE_DEFAULT_ROOM_ID=room-001

# 默认授权密钥（如需要）
VITE_DEFAULT_AUTH_TOKEN=your-auth-token-here

# iframe 嵌入的第三方渲染页面地址
VITE_IFRAME_RENDER_URL=http://你的IP地址:80/receiver/index.html

# 开发服务器端口
VITE_DEV_PORT=3000
